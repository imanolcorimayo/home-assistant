POSTGRES_PASSWORD=household123

# Any string. You'll paste the SAME value into Meta's webhook
# dashboard when you save the callback URL. Keep it long-ish and
# don't share it — it's what proves Meta is talking to you.
WHATSAPP_VERIFY_TOKEN=change-me-some-long-random-string

# Meta access token (System User, "Never" expiration recommended).
# Required to SEND messages and call any /v18.0/... endpoint.
WHATSAPP_ACCESS_TOKEN=

# Public identifiers from the Meta dashboard — NOT secrets, but the
# app needs them to build outbound URLs.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Gemini API key for transaction extraction (audio/photo/text).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
