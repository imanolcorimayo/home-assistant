POSTGRES_PASSWORD=household123

# Any string. You'll paste the SAME value into Meta's webhook
# dashboard when you save the callback URL. Keep it long-ish and
# don't share it — it's what proves Meta is talking to you.
WHATSAPP_VERIFY_TOKEN=change-me-some-long-random-string

# Meta access token (System User, "Never" expiration recommended).
# Required to SEND messages and call any /v18.0/... endpoint.
WHATSAPP_ACCESS_TOKEN=

# Public identifiers from the Meta dashboard — NOT secrets, but the
# app needs them to build outbound URLs.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Telegram bot token from @BotFather. Required to receive + send messages.
TELEGRAM_BOT_TOKEN=

# Random string echoed by Telegram in the X-Telegram-Bot-Api-Secret-Token
# header (registered via setWebhook?secret_token=...). Leave empty to skip
# the header check (NOT recommended in production).
TELEGRAM_WEBHOOK_SECRET=

# Token of the Consultor bot (analytics / read-only). A SEPARATE bot from
# the Registrador above — create another one in @BotFather.
CONSULTANT_TELEGRAM_BOT_TOKEN=

# Same idea as TELEGRAM_WEBHOOK_SECRET but for the Consultor webhook
# (/webhook/telegram-consultant).
CONSULTANT_TELEGRAM_WEBHOOK_SECRET=

# Gemini API key for transaction extraction (audio/photo/text).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=
