{
  "name": "household-web",
  "private": true,
  "version": "0.1.0",
  "description": "Tailwind v4 build for the household web app. Run `npm run css:build` before deploy.",
  "scripts": {
    "css:build": "tailwindcss -i app/static/input.css -o app/static/style.css --minify",
    "css:watch": "tailwindcss -i app/static/input.css -o app/static/style.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1"
  }
}
