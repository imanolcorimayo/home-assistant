# HTTP Basic Auth — browser asks for these before letting anyone in.
# AUTH_USER is shown in the prompt; AUTH_PASS is the secret.
BASIC_AUTH_USER=friend
BASIC_AUTH_PASS=change-me

# Cloudflare Tunnel token. Get it from:
#   Cloudflare dashboard → Zero Trust → Networks → Tunnels → Create a tunnel
#   Choose "Cloudflared", name it, then copy the token from the install command.
# It's a long base64-ish string starting with "eyJ".
TUNNEL_TOKEN=
