# Copiar a .env y completar con valores reales. Nunca commitear .env.
TELEGRAM_BOT_TOKEN=your_token_from_botfather_here
TELEGRAM_WEBHOOK_SECRET=generate_a_random_string_here

# Modelos de IA (qwen2.5:3b recomendado para máquinas con <8 GB RAM)
OLLAMA_MODEL=qwen2.5:3b
WHISPER_MODEL=small

# Password de Postgres. Lo usan api, worker, backup, metabase y Adminer.
# Importante: Postgres sólo lee este valor en la PRIMERA inicialización
# del volumen. Si ya existe la DB y querés cambiarlo, además de editar
# acá hay que correr dentro de Postgres:
#   ALTER USER sovereign WITH PASSWORD 'el-nuevo-password';
POSTGRES_PASSWORD=sovereign123

# HTTP Basic Auth para el dashboard web (puerto 8080).
# Dejar vacío en dev local. Setear cuando se expone públicamente
# (por ejemplo vía Cloudflare Tunnel). /webhook/* y /health quedan
# siempre abiertos para que Telegram y los health checks funcionen.
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
