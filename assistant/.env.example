# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# Shared Google OAuth client (one for all devs). Get these from Google Cloud
# Console → APIs & Services → Credentials → the "Web application" OAuth client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Any long random string (e.g. `openssl rand -hex 32`). Signs the session
# cookie. Keep it stable per-environment; changing it logs everyone out.
SESSION_SECRET=

# Optional — overrides the dev default (assistant123). Fine to leave unset
# locally since the DB port is bound to loopback only.
# POSTGRES_PASSWORD=
